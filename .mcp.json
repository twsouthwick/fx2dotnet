{
  "mcpServers": {
    "Microsoft.GitHubCopilot.AppModernization.Mcp": {
      "type": "stdio",
      "command": "dnx",
      "args": [
        "Microsoft.GitHubCopilot.AppModernization.Mcp@1.0.903-preview1",
        "--yes",
        "--source",
        "https://api.nuget.org/v3/index.json"
      ],
      "tools":
      [
        "convert_project_to_sdk_style",
        "get_projects_in_topological_order"
      ]
    }
  }
}